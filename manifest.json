{
  "id": "/",
  "name": "NavBuddy",
  "short_name": "NavBuddy",
  "description": "Professional celestial navigation suite — GNSS, sight reduction, tides, azimuth, voyage records and more.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "orientation": "any",
  "background_color": "#12151a",
  "theme_color": "#12151a",
  "lang": "en",
  "dir": "ltr",
  "categories": [
    "navigation",
    "utilities"
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "share_target": {
    "action": "./",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "icons": [
    {
      "src": "icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "GNSS Fix",
      "short_name": "GNSS",
      "url": "./?tab=gps",
      "description": "Acquire GPS fix"
    },
    {
      "name": "Sight Reduction",
      "short_name": "Sights",
      "url": "./?tab=sr",
      "description": "Celestial sight reduction"
    },
    {
      "name": "World Map",
      "short_name": "Map",
      "url": "./?tab=globe",
      "description": "World navigation map"
    },
    {
      "name": "Log Book",
      "short_name": "Log",
      "url": "./?tab=logbook",
      "description": "Voyage log book"
    }
  ]
}
